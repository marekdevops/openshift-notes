for node in <node1> <node2> <node3> <node4> <node7>; do
  echo "=== $node ==="
  oc debug node/$node -- chroot /host bash -c \
    "ls -la /dev/disk/by-id/ | grep -v part"
done


- name: kafka-thick
      nodeSelector:
        nodeSelectorTerms:
        - matchExpressions:
          - key: kafka-node
            operator: In
            values: ["true"]
      deviceSelector:
        optionalPaths:
        - /dev/disk/by-id/scsi-0QEMU_QEMU_HARDDISK_drive-ua-disk-kafka-UZUPELNIJ
        - /dev/disk/by-id/scsi-0QEMU_QEMU_HARDDISK_drive-ua-disk-kafka-UZUPELNIJ
        - /dev/disk/by-id/scsi-0QEMU_QEMU_HARDDISK_drive-ua-disk-kafka-UZUPELNIJ
