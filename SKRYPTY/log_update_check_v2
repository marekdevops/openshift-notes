def build_operators(co):
    if not co:
        return Panel("[red]Brak danych ClusterOperators[/red]",
                     title="OPERATORY", border_style="red")

    items       = co.get('items', [])
    active_rows = []
    ok_count    = 0

    for op in sorted(items, key=lambda x: x['metadata']['name']):
        name  = op['metadata']['name']
        conds = op.get('status', {}).get('conditions', [])

        is_prog   = bool_cond(get_condition(conds, 'Progressing').get('status'))
        is_degrad = bool_cond(get_condition(conds, 'Degraded').get('status'))

        if is_degrad:
            msg = truncate(get_condition(conds, 'Degraded').get('message', ''), 80)
            active_rows.append((name, 'degraded', msg))
        elif is_prog:
            msg = truncate(get_condition(conds, 'Progressing').get('message', ''), 80)
            active_rows.append((name, 'progressing', msg))
        else:
            ok_count += 1

    n_prog  = len([r for r in active_rows if r[1] == 'progressing'])
    n_degrad = len([r for r in active_rows if r[1] == 'degraded'])
    summary = (
        f"[bold]{len(items)}[/bold] operatorów  |  "
        f"[green]✓ {ok_count} OK[/green]  |  "
        f"[yellow]● {n_prog} Progressing[/yellow]  |  "
        f"[red]✗ {n_degrad} Degraded[/red]"
    )

    total_ops = len(items)
    bar_style = (
        "green"  if ok_count == total_ops else
        "red"    if n_degrad > 0          else
        "yellow"
    )
    bar_line = Text(
        f"  Postęp: {progress_bar(ok_count, total_ops, width=20)}  operatorów stabilnych",
        style=bar_style
    )

    if not active_rows:
        body = Text(f"✓ Wszystkie {ok_count} operatorów Available i stabilnych", style="green")
        return Panel(Group(bar_line, body),
                     title=f"[bold]OPERATORY[/bold]  –  {summary}", border_style="green")

    table = Table(box=box.SIMPLE_HEAVY, show_header=True,
                  header_style="bold white", expand=True)
    table.add_column("OPERATOR",  style="cyan", min_width=35, no_wrap=True)
    table.add_column("STATUS",    justify="center", min_width=12)
    table.add_column("WIADOMOŚĆ", overflow="fold")

    if ok_count:
        table.add_row(
            f"[dim]✓ {ok_count} operatorów Available[/dim]",
            "[dim green]OK[/dim green]", "",
        )
        table.add_section()

    for name, kind, msg in active_rows:
        if kind == 'degraded':
            table.add_row(name, "[bold red]DEGRADED[/bold red]", msg, style="on dark_red")
        else:
            table.add_row(name, "[bold yellow]PROGRESSING[/bold yellow]", msg, style="yellow")

    border = "red" if n_degrad > 0 else "yellow"
    return Panel(Group(bar_line, table),
                 title=f"[bold]OPERATORY[/bold]  –  {summary}", border_style=border)


# ---------------------------------------------------------------------------
# Sekcja 3: Etcd health — krytyczna podczas aktualizacji control plane
# ---------------------------------------------------------------------------

def build_etcd(etcd_data):
    """
    Pokazuje stan operatora etcd.
    Podczas aktualizacji OCP control plane aktualizuje się jako pierwsza:
    etcd → kube-apiserver → openshift-apiserver → pozostałe operatory.
    Degradacja etcd w tym oknie jest najpoważniejszym możliwym problemem.
    """
    if not etcd_data:
        return Panel(
            "[dim]Zasób 'etcd/cluster' niedostępny "
            "(OCP < 4.5 lub brak uprawnień cluster-reader)[/dim]",
            title="ETCD", border_style="dim"
        )

    conds = etcd_data.get('status', {}).get('conditions', [])

    members_avail    = get_condition(conds, 'EtcdMembersAvailable')
    members_prog     = get_condition(conds, 'EtcdMembersProgressing')
    members_degraded = get_condition(conds, 'EtcdMembersDegraded')
    installer_prog   = get_condition(conds, 'NodeInstallerProgressing')
    static_avail     = get_condition(conds, 'StaticPodsAvailable')

    lines = []

    def cond_line(label, cond, true_style="green", false_style="red"):
        """Dodaje linię dla jednego condition do lines."""
        st     = cond.get('status', 'Unknown')
        msg    = cond.get('message', '')
        reason = cond.get('reason', '')
        if st == 'True':
            icon  = '✓'
            style = true_style
            extra = f"  {truncate(msg, 90)}" if msg else ""
        elif st == 'False':
            icon  = '✗'
            style = false_style
            parts = []
            if reason:
                parts.append(f"[{reason}]")
            if msg:
                parts.append(truncate(msg, 90))
            extra = "  " + " ".join(parts) if parts else ""
        else:
            icon  = '?'
            style = "dim"
            extra = ""
        lines.append(Text(f"  {icon} {label}: {st}{extra}", style=style))

    # EtcdMembersAvailable=True → quorum OK (True=dobry, False=zły)
    cond_line("EtcdMembersAvailable",   members_avail,
              true_style="bold green", false_style="bold red")
    # EtcdMembersProgressing=True → trwa zmiana (True=w toku, False=stabilne)
    cond_line("EtcdMembersProgressing", members_prog,
              true_style="yellow",     false_style="dim green")
    # EtcdMembersDegraded=True → degradacja (True=zły, False=dobry)
    cond_line("EtcdMembersDegraded",    members_degraded,
              true_style="bold red",   false_style="green")

    # Dodatkowe conditions gdy istnieją (OCP 4.9+)
    if installer_prog.get('status') is not None or installer_prog:
        if installer_prog.get('status'):
            cond_line("NodeInstallerProgressing", installer_prog,
                      true_style="yellow", false_style="dim green")
    if static_avail.get('status'):
        cond_line("StaticPodsAvailable", static_avail,
                  true_style="green", false_style="red")

    is_avail    = bool_cond(members_avail.get('status'))
    is_degraded = bool_cond(members_degraded.get('status'))
    is_prog     = bool_cond(members_prog.get('status'))

    badge = (
        "[bold red]DEGRADED — QUORUM ZAGROŻONE[/bold red]" if is_degraded else
        "[yellow]PROGRESSING[/yellow]"                      if is_prog     else
        "[green]✓ OK[/green]"                               if is_avail    else
        "[dim]UNKNOWN[/dim]"
    )
    border = (
        "red"    if is_degraded else
        "yellow" if is_prog     else
        "green"  if is_avail    else
        "dim"
    )

    return Panel(Group(*lines), title=f"[bold]ETCD[/bold]  –  {badge}", border_style=border)


# ---------------------------------------------------------------------------
# Sekcja 4: MachineConfigPools
