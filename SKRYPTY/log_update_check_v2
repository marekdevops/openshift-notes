def _node_mco_state(node):
    """Zwraca (mco_state, mco_desired, mco_current, is_done) dla noda."""
    ann         = node['metadata'].get('annotations', {})
    mco_state   = ann.get('machineconfiguration.openshift.io/state', 'Done')
    mco_desired = ann.get('machineconfiguration.openshift.io/desiredConfig', '')
    mco_current = ann.get('machineconfiguration.openshift.io/currentConfig', '')
    is_done     = (
        mco_state not in ('Working', 'Degraded')
        and (not mco_desired or mco_desired == mco_current)
    )
    return mco_state, mco_desired, mco_current, is_done


def _node_role(node):
    lbl = node['metadata'].get('labels', {})
    if 'node-role.kubernetes.io/master' in lbl: return 'master'
    if 'node-role.kubernetes.io/infra'  in lbl: return 'infra'
    return 'worker'


def build_nodes(nodes, all_nodes=False, mcp_updated=None, mcp_total=None):
    if not nodes:
        return Panel("[red]Brak danych Nodes[/red]",
                     title="NODY", border_style="red")

    table = Table(box=box.SIMPLE_HEAVY, show_header=True,
                  header_style="bold white", expand=True)
    table.add_column("NODE",        style="cyan", min_width=30, no_wrap=True)
    table.add_column("ROLA",        justify="center", min_width=14)
    table.add_column("READY",       justify="center", min_width=8)
    table.add_column("SCHEDULABLE", justify="center", min_width=12)
    table.add_column("MCO STATE",   justify="center", min_width=10)
    table.add_column("VERSION",     style="dim", min_width=18, no_wrap=True)
    table.add_column("WERSJA OS",   style="dim", overflow="fold")

    def sort_key(n):
        order = {'master': 0, 'infra': 1, 'worker': 2}
        return (order.get(_node_role(n), 2), n['metadata']['name'])

    all_items = sorted(nodes.get('items', []), key=sort_key)
    total     = len(all_items)
    cordoned  = sum(
        1 for n in all_items if n.get('spec', {}).get('unschedulable', False)
    )

    # Rozdziel na widoczne i zwinięte (worker Done + Ready + schedulable)
    show_rows   = []
    hidden_done = []

    for node in all_items:
        role = _node_role(node)
        _, _, _, is_done = _node_mco_state(node)
        conds    = node.get('status', {}).get('conditions', [])
        is_ready = bool_cond(get_condition(conds, 'Ready').get('status'))
        is_cord  = node.get('spec', {}).get('unschedulable', False)

        # Zawsze pokazuj: mastery, infry, każdy nie-Done, Not-Ready, Cordoned
        if all_nodes or role != 'worker' or not is_done or not is_ready or is_cord:
            show_rows.append(node)
        else:
            hidden_done.append(node)

    for node in show_rows:
        name = node['metadata']['name']
        lbl  = node['metadata'].get('labels', {})

        roles = []
        if 'node-role.kubernetes.io/master' in lbl: roles.append('master')
        if 'node-role.kubernetes.io/infra'  in lbl: roles.append('infra')
        if 'node-role.kubernetes.io/worker' in lbl: roles.append('worker')
        role_str = '/'.join(roles) or 'worker'

        conds    = node.get('status', {}).get('conditions', [])
        is_ready = bool_cond(get_condition(conds, 'Ready').get('status'))
        ready_s  = "[green]✓ Ready[/green]" if is_ready else "[red]✗ NotReady[/red]"

        unschedulable = node.get('spec', {}).get('unschedulable', False)
        sched_s = "[yellow]Cordoned[/yellow]" if unschedulable else "[green]OK[/green]"

        mco_state, mco_desired, mco_current, _ = _node_mco_state(node)

        if mco_state == 'Degraded':
            mco_s     = "[bold red]Degraded[/bold red]"
            row_style = "on dark_red"
        elif mco_state == 'Working':
            mco_s     = "[bold yellow]Working[/bold yellow]"
            row_style = ""
        elif mco_desired and mco_desired != mco_current:
            mco_s     = "[yellow]Pending[/yellow]"
            row_style = ""
        else:
            mco_s     = "[green]Done[/green]"
            row_style = ""

        node_info   = node.get('status', {}).get('nodeInfo', {})
        kubelet_ver = node_info.get('kubeletVersion', 'N/A')
        os_image    = node_info.get('osImage', 'N/A')
        table.add_row(
            name, role_str, ready_s, sched_s, mco_s,
            kubelet_ver, os_image[:35],
            style=row_style
        )

    if hidden_done:
        table.add_row(
            f"[dim]... {len(hidden_done)} worker nodes[/dim]",
            "[dim]worker[/dim]",
            "[dim]✓ Ready[/dim]",
            "[dim]OK[/dim]",
            "[dim green]Done (wszystkie)[/dim green]",
            "", "[dim]ukryte — użyj --all-nodes[/dim]",
        )

    summary = f"[bold]{total}[/bold] nodów"
    if cordoned:
        summary += f"  |  [yellow]{cordoned} cordoned[/yellow]"
    if hidden_done:
        summary += f"  |  [dim]{len(hidden_done)} worker Done (zwinięte)[/dim]"

    # Pasek postępu z MCP — bardziej wiarygodny niż MCO annotations na nodzie
    if mcp_updated is not None and mcp_total is not None and mcp_total > 0:
        bar_style    = "green" if mcp_updated == mcp_total else "yellow"
        node_bar_line = Text(
            f"  Postęp: {progress_bar(mcp_updated, mcp_total, width=20)}"
            "  nodów zaktualizowanych (wg MCP)",
            style=bar_style
        )
    else:
        node_bar_line = Text("  Postęp: N/A", style="dim")

    return Panel(
        Group(node_bar_line, table),
        title=f"[bold]NODY[/bold]  –  {summary}",
        border_style="blue"
    )


# ---------------------------------------------------------------------------
# Sekcja 6: Pending CSR-y
# ---------------------------------------------------------------------------

def build_csrs(csr_data):
    if not csr_data:
        return None

    pending = [
        c for c in csr_data.get('items', [])
        if not c.get('status', {}).get('conditions')
    ]

    if not pending:
        return None

    table = Table(box=box.SIMPLE, show_header=True, header_style="bold", expand=True)
    table.add_column("NAZWA",      style="cyan")
    table.add_column("REQUESTER")
    table.add_column("UŻYTKOWNIK")
    table.add_column("WIEK")

    for csr in pending[:10]:
        name      = csr['metadata']['name']
        spec      = csr.get('spec', {})
        created   = csr['metadata'].get('creationTimestamp', '')
        age       = elapsed_since(created)
        requester = spec.get('signerName', '')
        username  = spec.get('username', '')
        table.add_row(name, requester, username, age)

    approve_hint = Text.from_markup(
        "  [yellow]→ Zatwierdź wszystkie (tylko po weryfikacji!):[/yellow]\n"
        "    [bold]oc get csr -o name | xargs oc adm certificate approve[/bold]"
    )

    return Panel(
        Group(table, approve_hint),
        title=(
            f"[bold red]⚠ PENDING CSR-Y ({len(pending)})[/bold red]"
            "  – mogą blokować dołączanie nodów"
        ),
        border_style="red"
    )


# ---------------------------------------------------------------------------
# Sekcja 7: Problematyczne pody w namespace'ach systemowych
# ---------------------------------------------------------------------------

def build_bad_pods(pods_data):
    if not pods_data:
        return None

    BAD_PHASES    = {'Failed'}
    BAD_REASONS   = {
        'CrashLoopBackOff', 'Error', 'OOMKilled',
        'ImagePullBackOff', 'ErrImagePull',
    }
    SYSTEM_PREFIX = ('openshift-', 'kube-')

    bad = []
    for pod in pods_data.get('items', []):
        ns   = pod['metadata']['namespace']
        name = pod['metadata']['name']

        if not any(ns.startswith(p) for p in SYSTEM_PREFIX):
            continue

        phase = pod.get('status', {}).get('phase', '')
        if phase in BAD_PHASES:
            bad.append((ns, name, phase, ''))
            continue

        # Init containers — sprawdzaj przed głównymi (częste podczas rollout)
        init_found = False
        for cs in pod.get('status', {}).get('initContainerStatuses', []):
            reason = cs.get('state', {}).get('waiting', {}).get('reason', '')
            if reason in BAD_REASONS:
                bad.append((ns, f"{name} [dim](init: {cs.get('name','')})[/dim]",
                             phase, reason))
                init_found = True
                break

        if init_found:
            continue

        # Główne containers
        for cs in pod.get('status', {}).get('containerStatuses', []):
            reason = cs.get('state', {}).get('waiting', {}).get('reason', '')
            if reason in BAD_REASONS:
                bad.append((ns, name, phase, reason))
                break

    if not bad:
        return None

    table = Table(box=box.SIMPLE, show_header=True, header_style="bold", expand=True)
    table.add_column("NAMESPACE", style="cyan", no_wrap=True)
    table.add_column("POD",       no_wrap=True)
    table.add_column("PHASE")
    table.add_column("REASON")

    for ns, name, phase, reason in bad[:20]:
        table.add_row(ns, name, phase,
                      f"[red]{reason}[/red]" if reason else phase)

    if len(bad) > 20:
        table.add_row(
            "[dim]...[/dim]",
            f"[dim]... i {len(bad) - 20} więcej[/dim]",
            "", ""
        )

    return Panel(
        table,
        title=(
            f"[bold red]⚠ PROBLEMATYCZNE PODY W NAMESPACE'ACH SYSTEMOWYCH"
            f" ({len(bad)})[/bold red]"
        ),
        border_style="red"
    )


# ---------------------------------------------------------------------------
# Sekcja 8: Eventy — MCO + CVO (połączone, posortowane)
# ---------------------------------------------------------------------------

def build_events(events_mco, events_cvo):
    """
    Łączy eventy z namespace'ów MCO i CVO, sortuje malejąco po czasie
    i pokazuje ostatnie 15. CVO odpowiada za orchestrację całej aktualizacji,
    MCO — za aktualizację nodów.
    """
    all_items = []
    for source in (events_mco, events_cvo):
        if source:
            all_items.extend(source.get('items', []))

    if not all_items:
        return Panel(
            "[dim]Brak eventów z MCO / CVO[/dim]",
            title="OSTATNIE ZDARZENIA (MCO + CVO)", border_style="dim"
        )

    sorted_items = sorted(
        all_items,
        key=lambda e: e.get('lastTimestamp') or e.get('eventTime') or '',
        reverse=True
    )[:15]

    table = Table(box=box.SIMPLE, show_header=True, header_style="bold", expand=True)
    table.add_column("CZAS",      style="dim", no_wrap=True, min_width=19)
    table.add_column("NS",        style="dim", min_width=5,  no_wrap=True)
    table.add_column("TYP",       justify="center", min_width=8)
    table.add_column("POWÓD",     min_width=14)
    table.add_column("OBIEKT",    min_width=20, no_wrap=True)
    table.add_column("WIADOMOŚĆ", overflow="fold")

    for ev in sorted_items:
        ev_type = ev.get('type', 'Normal')
        reason  = ev.get('reason', '')
        ns      = ev.get('metadata', {}).get('namespace', '')
        obj     = ev.get('involvedObject', {})
        obj_str = f"{obj.get('kind','')}/{obj.get('name','')}"
        msg     = truncate(ev.get('message', ''), 70)
        ts_raw  = ev.get('lastTimestamp') or ev.get('eventTime') or ''
        ts      = ts_raw[:19].replace('T', ' ')

        # Skróć namespace dla czytelności kolumny
        ns_short = (
            "mco" if 'machine-config' in ns else
            "cvo" if 'cluster-version' in ns else
            ns[:8]
        )

        type_s = (
            f"[yellow]{ev_type}[/yellow]" if ev_type == 'Warning' else
            f"[dim]{ev_type}[/dim]"
        )
        table.add_row(ts, ns_short, type_s, reason, obj_str, msg)

    return Panel(
        table,
        title=(
            "[bold]OSTATNIE ZDARZENIA — "
            "openshift-machine-config-operator"
            "  +  "
            "openshift-cluster-version-operator[/bold]"
        ),
        border_style="dim"
    )


# ---------------------------------------------------------------------------
# Zbieranie danych — równoległe wywołania oc
# ---------------------------------------------------------------------------

_last_refresh_ts = "nigdy"


def collect_data():
    """
    Pobiera wszystkie dane z klastra równolegle (ThreadPoolExecutor).
    W v1 wywołania były sekwencyjne — przy wolnym API podczas aktualizacji
    control plane mogło to powodować opóźnienia do 140 s (7 × 20 s timeout).
    """
    tasks = {
        'cv': lambda: get_json(
            ['get', 'clusterversion', 'version', '-o', 'json']),
        'co': lambda: get_json(
            ['get', 'clusteroperators', '-o', 'json']),
        'mcp': lambda: get_json(
            ['get', 'mcp', '-o', 'json']),
        'nodes': lambda: get_json(
            ['get', 'nodes', '-o', 'json']),
        'etcd': lambda: get_json(
            ['get', 'etcd', 'cluster', '-o', 'json']),
        'csr': lambda: get_json(
            ['get', 'csr', '-o', 'json']),
        'pods': lambda: get_json(
            ['get', 'pods', '-A', '--field-selector=status.phase!=Running',
             '-o', 'json'], timeout=30),
        'events_mco': lambda: get_json(
            ['get', 'events',
             '-n', 'openshift-machine-config-operator',
             '--sort-by=.lastTimestamp', '-o', 'json']),
        'events_cvo': lambda: get_json(
            ['get', 'events',
             '-n', 'openshift-cluster-version-operator',
             '--sort-by=.lastTimestamp', '-o', 'json']),
    }

    results = {}
    with ThreadPoolExecutor(max_workers=len(tasks)) as pool:
        future_to_key = {pool.submit(fn): key for key, fn in tasks.items()}
        for future in as_completed(future_to_key):
            key = future_to_key[future]
            try:
                results[key] = future.result()
            except Exception:
                results[key] = None

    return results


def collect_and_render(interval, all_nodes=False):
    """Pobiera dane równolegle i buduje kompletny widok dashboardu."""
    global _last_refresh_ts

    data = collect_data()
    _last_refresh_ts = datetime.now().strftime("%H:%M:%S")

    cv         = data.get('cv')
    co         = data.get('co')
    mcp        = data.get('mcp')
    nodes      = data.get('nodes')
    etcd       = data.get('etcd')
    csr        = data.get('csr')
    pods       = data.get('pods')
    events_mco = data.get('events_mco')
    events_cvo = data.get('events_cvo')

    # Postęp nodów liczony z kondycji MCP (bardziej wiarygodny niż MCO annotations)
    mcp_items         = (mcp or {}).get('items', [])
    mcp_total         = 0
    mcp_updated       = 0
    mcp_is_any_updating = False

    for pool_item in mcp_items:
        machine_count = pool_item.get('status', {}).get('machineCount', 0)
        updated_count = pool_item.get('status', {}).get('updatedMachineCount', 0)
        conds         = pool_item.get('status', {}).get('conditions', [])
        is_updated    = bool_cond(
            get_condition(conds, 'MachineConfigPoolUpdated').get('status'))
        is_updating   = bool_cond(
            get_condition(conds, 'MachineConfigPoolUpdating').get('status'))

        mcp_total += machine_count
        if is_updated:
            mcp_updated += machine_count   # cała pula gotowa
        elif is_updating:
            mcp_updated += updated_count   # pula w trakcie — częściowo
            mcp_is_any_updating = True

    # Dane dla StallDetector
    cv_conds     = (cv or {}).get('status', {}).get('conditions', [])
    cvo_prog     = get_condition(cv_conds, 'Progressing')
    cvo_is_prog  = bool_cond(cvo_prog.get('status'))
    cvo_prog_msg = cvo_prog.get('message', '')

    node_stall_secs, cvo_stall_secs = _stall_detector.update(
        mcp_updated, mcp_is_any_updating,
        cvo_prog_msg, cvo_is_prog
    )

    sections = [
        Rule(
            f"[dim] OpenShift Update Monitor  |  odświeżono: {_last_refresh_ts}"
            f"  |  interwał: {interval}s  |  Ctrl+C aby wyjść [/dim]"
        ),
        build_header(cv),
    ]

    # Ostrzeżenie o stall — zaraz po nagłówku, gdy wykryto brak postępu
    stall_panel = build_stall_warning(node_stall_secs, cvo_stall_secs, cvo_prog_msg)
    if stall_panel:
        sections.append(stall_panel)

    sections += [
        build_operators(co),
        build_etcd(etcd),
        build_mcp(mcp),
        build_nodes(nodes, all_nodes=all_nodes,
                    mcp_updated=mcp_updated, mcp_total=mcp_total),
    ]

    csr_panel = build_csrs(csr)
    if csr_panel:
        sections.append(csr_panel)

    bad_pods_panel = build_bad_pods(pods)
    if bad_pods_panel:
        sections.append(bad_pods_panel)

    sections.append(build_events(events_mco, events_cvo))

    return Group(*sections)


# ---------------------------------------------------------------------------
# Główna pętla
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        description="OpenShift Update Monitor — live dashboard procesu aktualizacji",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Uruchamiaj jako użytkownik z uprawnieniami cluster-reader.\n\n"
            "Tryby wyświetlania:\n"
            "  (domyślny)   clear + print co interval sekund, można scrollować\n"
            "  --screen     Rich full-screen — jak htop, content musi mieścić się w oknie\n"
            "  --log        tryb append — każde odświeżenie dokłada blok na dół\n\n"
            "Przykłady:\n"
            "  ./log_update_check\n"
            "  ./log_update_check --interval 15\n"
            "  ./log_update_check --all-nodes\n"
            "  ./log_update_check --screen\n"
            "  ./log_update_check --log >> update-$(date +%F).log\n"
            "  ./log_update_check --context hub-cluster\n"
            "  ./log_update_check --kubeconfig /home/admin/.kube/spoke1"
        )
    )
    parser.add_argument(
        '--interval', '-i',
        type=int, default=30, metavar='SEKUNDY',
        help='Interwał odświeżania w sekundach (domyślnie: 30)'
    )
    parser.add_argument(
        '--screen',
        action='store_true',
        help='Tryb Rich full-screen (jak htop) — content musi mieścić się w oknie terminala'
    )
    parser.add_argument(
        '--log',
        action='store_true',
        help='Tryb append — każde odświeżenie dodaje blok z timestampem (do logowania)'
    )
    parser.add_argument(
        '--all-nodes',
        action='store_true',
        help='Pokaż wszystkie nody (domyślnie: worker Done są zwijane do jednej linii)'
    )
    parser.add_argument(
        '--context',
        metavar='CONTEXT',
        help='kubeconfig context (przekazywany jako oc --context)'
    )
    parser.add_argument(
        '--kubeconfig',
        metavar='PLIK',
        help='Ścieżka do pliku kubeconfig (przekazywana jako oc --kubeconfig)'
    )
    args = parser.parse_args()

    # Zbuduj globalne flagi oc — używane przez każde wywołanie run_oc()
    global OC_GLOBAL_FLAGS
    if args.kubeconfig:
        OC_GLOBAL_FLAGS += ['--kubeconfig', args.kubeconfig]
    if args.context:
        OC_GLOBAL_FLAGS += ['--context', args.context]

    # Weryfikacja połączenia
    stdout, err = run_oc(['whoami'])
    if err or not stdout:
        console.print("[red]BLAD: Nie jesteś zalogowany. Wykonaj: oc login <server>[/red]")
        sys.exit(1)

    user       = stdout.strip()
    server_out, _ = run_oc(['whoami', '--show-server'])
    server     = (server_out or '').strip()

    if not args.screen:
        console.print(
            f"[green]✓[/green] Zalogowany jako: [cyan]{user}[/cyan]"
            f"  |  Klaster: [cyan]{server}[/cyan]"
        )
        console.print(f"[dim]Interwał: {args.interval}s  |  Ctrl+C aby wyjść[/dim]")
        time.sleep(1)

    if args.log:
        # Tryb append — każdy blok opatrzony wyraźnym timestampem
        # Ułatwia analizę post-mortem: grep "^─" update.log | head
        try:
            while True:
                ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                console.rule(f"[bold dim] ▶  {ts}  ◀ [/bold dim]")
                console.print(collect_and_render(args.interval, args.all_nodes))
                console.rule(f"[dim] ■  koniec bloku {ts} [/dim]")
                time.sleep(args.interval)
        except KeyboardInterrupt:
            console.print("\n[dim]Zatrzymano.[/dim]")

    elif args.screen:
        # Tryb Rich full-screen — content musi mieścić się w oknie terminala
        try:
            with Live(
                collect_and_render(args.interval, args.all_nodes),
                console=console,
                screen=True,
                refresh_per_second=1
            ) as live:
                while True:
                    time.sleep(args.interval)
                    live.update(collect_and_render(args.interval, args.all_nodes))
        except KeyboardInterrupt:
            pass
        console.print("[dim]Zatrzymano.[/dim]")

    else:
        # Tryb domyślny: clear + print co interval sekund
        # Między odświeżeniami terminal jest w pełni scrollowalny
        try:
            while True:
                console.clear()
                console.print(collect_and_render(args.interval, args.all_nodes))
                time.sleep(args.interval)
        except KeyboardInterrupt:
            console.print("\n[dim]Zatrzymano.[/dim]")


if __name__ == '__main__':
    main()
