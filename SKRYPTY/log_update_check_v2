# Detekcja zawieszonej aktualizacji
# ---------------------------------------------------------------------------

class StallDetector:
    """
    Śledzi postęp aktualizacji między odświeżeniami.

    Dwa niezależne kanały detekcji:
    - MCP: jeśli updatedMachineCount nie zmienia się przez NODE_STALL_MIN minut
      podczas aktywnego updating → możliwy hang na drainowaniu/rebootowaniu noda.
    - CVO: jeśli wiadomość warunku Progressing nie zmienia się przez CVO_STALL_MIN
      minut podczas aktywnej aktualizacji → operator może być zawieszony.
    """
    NODE_STALL_SECS = 20 * 60   # 20 min bez postępu w nodach
    CVO_STALL_SECS  = 15 * 60   # 15 min bez zmiany komunikatu CVO

    def __init__(self):
        self._last_mcp_updated      = None
        self._last_mcp_change_time  = None
        self._last_cvo_msg          = None
        self._last_cvo_change_time  = None

    def update(self, mcp_updated, mcp_is_updating, cvo_prog_msg, cvo_is_progressing):
        """
        Aktualizuje stan i zwraca (node_stall_secs, cvo_stall_secs).
        Wartości None oznaczają brak stall.
        """
        now = datetime.now(timezone.utc)

        # --- MCP node stall ---
        node_stall_secs = None
        if mcp_is_updating:
            if self._last_mcp_updated != mcp_updated:
                self._last_mcp_updated     = mcp_updated
                self._last_mcp_change_time = now
            elif self._last_mcp_change_time is not None:
                stalled = (now - self._last_mcp_change_time).total_seconds()
                if stalled >= self.NODE_STALL_SECS:
                    node_stall_secs = int(stalled)
        else:
            self._last_mcp_updated     = None
            self._last_mcp_change_time = None

        # --- CVO stall ---
        cvo_stall_secs = None
        if cvo_is_progressing and cvo_prog_msg:
            if self._last_cvo_msg != cvo_prog_msg:
                self._last_cvo_msg         = cvo_prog_msg
                self._last_cvo_change_time = now
            elif self._last_cvo_change_time is not None:
                stalled = (now - self._last_cvo_change_time).total_seconds()
                if stalled >= self.CVO_STALL_SECS:
                    cvo_stall_secs = int(stalled)
        else:
            self._last_cvo_msg         = None
            self._last_cvo_change_time = None

        return node_stall_secs, cvo_stall_secs


_stall_detector = StallDetector()


def build_stall_warning(node_stall_secs, cvo_stall_secs, cvo_msg):
    """Panel ostrzeżenia gdy aktualizacja wygląda na zawieszoną. Zwraca None gdy OK."""
    if node_stall_secs is None and cvo_stall_secs is None:
        return None

    lines = []

    def hms(secs):
        h, rem = divmod(secs, 3600)
        m, s   = divmod(rem, 60)
        return f"{h}h {m:02d}m {s:02d}s"

    if node_stall_secs is not None:
        lines.append(Text(
            f"  ⚠  Brak postępu w nodach (MCP updatedMachineCount) od {hms(node_stall_secs)}",
            style="bold red"
        ))
        lines.append(Text(
            "     Możliwe przyczyny: node nie odpowiada na drain, pętla reboot, problem z MCD",
            style="red"
        ))
        lines.append(Text.from_markup(
            "     Diagnoza: [bold]oc get nodes[/bold]  |  "
            "[bold]oc get pods -n openshift-machine-config-operator[/bold]  |  "
            "[bold]oc get mcp[/bold]"
        ))

    if cvo_stall_secs is not None:
        lines.append(Text(
            f"  ⚠  CVO nie robi postępu od {hms(cvo_stall_secs)}",
            style="bold red"
        ))
        lines.append(Text(
            f"     Ostatni komunikat CVO: {truncate(cvo_msg, 100)}",
            style="red"
        ))
        lines.append(Text.from_markup(
            "     Diagnoza: [bold]oc get co[/bold]  |  "
            "[bold]oc logs -n openshift-cluster-version-operator "
            "deploy/cluster-version-operator --tail=50[/bold]"
        ))

    return Panel(
        Group(*lines),
        title="[bold red]⚠  UWAGA: AKTUALIZACJA MOŻE BYĆ ZAWIESZONA  ⚠[/bold red]",
        border_style="red"
    )


