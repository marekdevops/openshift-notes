<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ocp-sizer — Raport sizingu klastra</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', Tahoma, sans-serif; background: #0f1117; color: #e2e8f0; line-height: 1.6; }
  .container { max-width: 1400px; margin: 0 auto; padding: 24px; }
  h1 { font-size: 1.8rem; color: #63b3ed; border-bottom: 2px solid #2d3748; padding-bottom: 12px; margin-bottom: 8px; }
  h2 { font-size: 1.2rem; color: #90cdf4; margin: 32px 0 12px; }
  .meta { color: #718096; font-size: 0.9rem; margin-bottom: 24px; }
  .meta span { margin-right: 20px; }
  .badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 0.8rem; font-weight: bold; }
  .badge-green { background: #276749; color: #9ae6b4; }
  .badge-red   { background: #742a2a; color: #feb2b2; }
  .badge-dim   { background: #2d3748; color: #a0aec0; }
  table { width: 100%; border-collapse: collapse; font-size: 0.88rem; }
  th { background: #1a202c; color: #90cdf4; padding: 10px 12px; text-align: left; border-bottom: 2px solid #2d3748; white-space: nowrap; }
  td { padding: 8px 12px; border-bottom: 1px solid #2d3748; vertical-align: middle; }
  tr:hover td { background: #1a202c; }
  .num { text-align: right; font-family: monospace; }
  .green { color: #68d391; }
  .yellow { color: #f6e05e; }
  .red { color: #fc8181; }
  .dim { color: #718096; }
  .recommended { border-left: 4px solid #48bb78; }
  .recommended td:first-child::before { content: "★ "; color: #48bb78; }
  .warn-row td { background: #2d2a1a; }
  .section { background: #1a202c; border-radius: 8px; padding: 16px; margin-bottom: 24px; overflow-x: auto; }
  .totals-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 24px; }
  .stat-card { background: #1a202c; border-radius: 8px; padding: 16px; border-left: 4px solid #4299e1; }
  .stat-card .label { font-size: 0.8rem; color: #718096; margin-bottom: 4px; }
  .stat-card .value { font-size: 1.4rem; font-weight: bold; color: #90cdf4; font-family: monospace; }
  .reasoning { font-size: 0.8rem; color: #718096; margin-top: 4px; }
  .reasoning li { margin-left: 16px; }
  details summary { cursor: pointer; color: #90cdf4; }
  .warning-box { background: #2d2a1a; border-left: 4px solid #f6e05e; padding: 8px 12px; margin: 4px 0; border-radius: 0 4px 4px 0; font-size: 0.85rem; color: #f6e05e; }
</style>
</head>
<body>
<div class="container">
  <h1>ocp-sizer — Raport sizingu klastra</h1>
  <div class="meta">
    <span>Klaster: <strong>{{ sizing.source_cluster_context }}</strong></span>
    <span>Wygenerowano: {{ sizing.generated_at }}</span>
    <span>Namespace'y: {{ sizing.namespaces | length }}</span>
    <span>Metrics-server:
      {% if sizing.metrics_available %}
        <span class="badge badge-green">dostępne</span>
      {% else %}
        <span class="badge badge-dim">niedostępne</span>
      {% endif %}
    </span>
  </div>

  <!-- Totals cards -->
  <div class="totals-grid">
    <div class="stat-card">
      <div class="label">Łączne CPU Requests</div>
      <div class="value">{{ sizing.cluster_totals_requests | fmt_cpu }}</div>
    </div>
    <div class="stat-card">
      <div class="label">Łączne RAM Requests</div>
      <div class="value">{{ sizing.cluster_totals_requests | fmt_mem }}</div>
    </div>
    <div class="stat-card">
      <div class="label">Łączne CPU Limits</div>
      <div class="value">{{ sizing.cluster_totals_limits | fmt_cpu }}</div>
    </div>
    <div class="stat-card">
      <div class="label">Łączne RAM Limits</div>
      <div class="value">{{ sizing.cluster_totals_limits | fmt_mem }}</div>
    </div>
    <div class="stat-card">
      <div class="label">DaemonSet overhead / node</div>
      <div class="value" style="font-size:1rem;">
        {{ sizing.daemonset_overhead_per_node | fmt_cpu }} CPU<br>
        {{ sizing.daemonset_overhead_per_node | fmt_mem }} RAM
      </div>
    </div>
    <div class="stat-card">
      <div class="label">Min nodes (PDB / anti-affinity)</div>
      <div class="value">{{ sizing.global_min_nodes_from_constraints }}</div>
    </div>
  </div>

  <!-- Namespace summary -->
  <h2>Namespace Summary</h2>
  <div class="section">
    <table>
      <thead>
        <tr>
          <th>Namespace</th>
          <th>Pods (all/run)</th>
          <th class="num">Req CPU</th>
          <th class="num">Req RAM</th>
          <th class="num">Lim CPU</th>
          <th class="num">Lim RAM</th>
          <th class="num">Act CPU%</th>
          <th class="num">Act RAM%</th>
          <th class="num">Nodes</th>
          <th class="num">PDB min</th>
          <th class="num">AA min</th>
          <th>NodeSelector</th>
        </tr>
      </thead>
      <tbody>
        {% for ns in sizing.namespaces %}
        <tr>
          <td><strong>{{ ns.namespace }}</strong></td>
          <td class="num">{{ ns.pod_count }} / {{ ns.running_pod_count }}</td>
          <td class="num green">{{ ns.total_requests.cpu_millicores | fmt_cpu }}</td>
          <td class="num green">{{ ns.total_requests.memory_bytes | fmt_mem }}</td>
          <td class="num yellow">{{ ns.total_limits.cpu_millicores | fmt_cpu }}</td>
          <td class="num yellow">{{ ns.total_limits.memory_bytes | fmt_mem }}</td>
          <td class="num">
            {% if ns.actual_usage and ns.total_requests.cpu_millicores > 0 %}
              {% set pct = (ns.actual_usage.cpu_millicores / ns.total_requests.cpu_millicores * 100) | round(1) %}
              <span class="{{ 'red' if pct > 90 else ('yellow' if pct > 75 else 'green') }}">{{ pct }}%</span>
            {% else %}<span class="dim">-</span>{% endif %}
          </td>
          <td class="num">
            {% if ns.actual_usage and ns.total_requests.memory_bytes > 0 %}
              {% set pct = (ns.actual_usage.memory_bytes / ns.total_requests.memory_bytes * 100) | round(1) %}
              <span class="{{ 'red' if pct > 90 else ('yellow' if pct > 75 else 'green') }}">{{ pct }}%</span>
            {% else %}<span class="dim">-</span>{% endif %}
          </td>
          <td class="num">{{ ns.active_nodes | length }}</td>
          <td class="num">{{ ns.pdb_min_nodes if ns.pdb_min_nodes else '-' }}</td>
          <td class="num">{{ ns.anti_affinity_min_nodes if ns.anti_affinity_min_nodes else '-' }}</td>
          <td class="dim">{{ ns.node_selectors[:2] | join(', ') }}{% if ns.node_selectors | length > 2 %} +{{ ns.node_selectors | length - 2 }}{% endif %}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <!-- Sizing recommendations -->
  <h2>Rekomendacje Sizingu</h2>
  <div class="section">
    <table>
      <thead>
        <tr>
          <th>Wariant</th>
          <th>Rozmiar node'a</th>
          <th class="num">Liczba workerów</th>
          <th class="num">CPU util (N-1)</th>
          <th class="num">RAM util (N-1)</th>
          <th>Driver</th>
          <th>Uzasadnienie</th>
        </tr>
      </thead>
      <tbody>
        {% for v in sizing.sizing_variants %}
        {% if v.driver != 'unusable' %}
        <tr class="{{ 'recommended' if v.is_recommended }}">
          <td><strong>{{ v.node_variant.label }}</strong></td>
          <td>{{ v.node_variant.cpu_cores }}CPU / {{ v.node_variant.memory_gib }}GiB</td>
          <td class="num"><strong>{{ v.worker_count }}</strong></td>
          <td class="num">
            {% set pct = (v.utilization_cpu_pct * 100) | round(1) %}
            <span class="{{ 'red' if pct > 90 else ('yellow' if pct > 75 else 'green') }}">{{ pct }}%</span>
          </td>
          <td class="num">
            {% set pct = (v.utilization_mem_pct * 100) | round(1) %}
            <span class="{{ 'red' if pct > 90 else ('yellow' if pct > 75 else 'green') }}">{{ pct }}%</span>
          </td>
          <td class="dim">{{ v.driver }}</td>
          <td>
            <details>
              <summary>szczegóły</summary>
              <ul class="reasoning">
                {% for r in v.reasoning %}<li>{{ r }}</li>{% endfor %}
              </ul>
            </details>
          </td>
        </tr>
        {% if v.warnings %}
        <tr class="warn-row">
          <td colspan="7">
            {% for w in v.warnings %}
            <div class="warning-box">⚠ {{ w }}</div>
            {% endfor %}
          </td>
        </tr>
        {% endif %}
        {% endif %}
        {% endfor %}
      </tbody>
    </table>
    <p style="margin-top:12px; color:#718096; font-size:0.85rem;">★ = rekomendowany wariant (najbliżej 75% target utilization) | N-1 = liczba aktywnych node'ów podczas drain jednego</p>
  </div>

</div>
</body>
</html>
