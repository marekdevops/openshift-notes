#!/bin/bash

# Ustaw swoją domenę lub fragment nazwy routy
DOMENA="MOJA_DOMENA"
NAMESPACE="openshift-ingress"

echo "--- Rozpoczynam przeszukiwanie wszystkich routerów dla: $DOMENA ---"

# Pobranie listy wszystkich podów routera
ROUTER_PODS=$(oc get pods -n $NAMESPACE -o name | grep router-default)

for pod in $ROUTER_PODS; do
    echo "Sprawdzam pod: $pod..."
    
    # Wyciągamy logi z kontenera 'logs' (używamy --tail, żeby nie czytać GB danych)
    # Filtrujemy po domenie i szukamy błędów 5xx
    oc logs -n $NAMESPACE $pod -c logs --tail=5000 | grep "$DOMENA" | awk '$11 ~ /^5/ {print "ZNALAZŁEM BŁĄD: " $0}'
done

echo "--- Koniec przeszukiwania ---"