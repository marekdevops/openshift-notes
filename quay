apiVersion: v1
  kind: Secret
  metadata:
    name: quay-config-bundle
    namespace: quay-registry                                                                                                                                                                                                                           
  stringData:
    config.yaml: |                                                                                                                                                                                                                                     
      DISTRIBUTED_STORAGE_CONFIG:                           
        default:
          - LocalStorage
          - storage_path: /datastorage/registry
      DISTRIBUTED_STORAGE_DEFAULT_LOCATIONS: []                                                                                                                                                                                                        
      DISTRIBUTED_STORAGE_PREFERENCE:
        - default                                                                                                                                                                                                                                      
                                                            
  ---
  Krok 3 — QuayRegistry

  apiVersion: quay.redhat.com/v1
  kind: QuayRegistry                                                                                                                                                                                                                                   
  metadata:
    name: quay                                                                                                                                                                                                                                         
    namespace: quay-registry                                
  spec:
    configBundleSecret: quay-config-bundle
    components:
      - kind: objectstorage
        managed: false                                                                                                                                                                                                                                 
      - kind: postgres
        managed: true                                                                                                                                                                                                                                  
      - kind: redis                                         
        managed: true
      - kind: route
        managed: true
      - kind: quay
        managed: true                                                                                                                                                                                                                                  
        overrides:
          volumeMounts:                                                                                                                                                                                                                                
            - name: quay-storage                            
              mountPath: /datastorage/registry
          volumes:                                                                                                                                                                                                                                     
            - name: quay-storage
              persistentVolumeClaim:                                                                                                                                                                                                                   
                claimName: quay-storage                     

